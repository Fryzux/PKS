@inherits LayoutComponentBase
@using CorporateSystem.Client.Services
@inject ThemeService Theme

<div class="app-root @Theme.CurrentTheme">
    <nav class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-building"></i>
            <span>CorporateSystem</span>
        </div>
        <NavMenu />
    </nav>

    <div class="main-area">
        <header class="top-bar">
            <div class="top-bar-left">
                <span class="welcome-text">Корпоративная система управления</span>
            </div>
            <div class="top-bar-right">
                <button class="theme-toggle" @onclick="ToggleTheme" title="Переключить тему">
                    <i class="bi @(Theme.IsDark ? "bi-sun-fill" : "bi-moon-stars-fill")"></i>
                </button>
            </div>
        </header>

        <main class="content-area">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui">
    Произошла необработанная ошибка.
    <a href="" class="reload">Перезагрузить</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Theme.InitializeAsync();
            Theme.OnThemeChanged += OnThemeChanged;
            StateHasChanged();
        }
    }

    private void OnThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleTheme()
    {
        await Theme.ToggleThemeAsync();
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= OnThemeChanged;
    }
}
