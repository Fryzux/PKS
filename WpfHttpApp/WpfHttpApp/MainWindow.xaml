<Window x:Class="WpfHttpApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHttpApp"
        xmlns:vm="clr-namespace:WpfHttpApp.ViewModels"
        xmlns:models="clr-namespace:WpfHttpApp.Models"
        mc:Ignorable="d"
        Title="WPF HTTP Core - Senior Architecture" Height="600" Width="900"
        Background="#1E1E1E">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <DataTemplate DataType="{x:Type models:LogEntry}">
            <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}" Foreground="#888"/>
                    
                    <Border Grid.Column="1" CornerRadius="3" Padding="4,2" HorizontalAlignment="Left" Margin="5,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Level}" Value="Info">
                                        <Setter Property="Background" Value="#2E5A27"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                        <Setter Property="Background" Value="#7A651F"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                        <Setter Property="Background" Value="#7A2F2F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Level}" FontWeight="Bold" Foreground="White" FontSize="10"/>
                    </Border>
                    
                    <TextBlock Grid.Column="2" Text="{Binding Source}" Foreground="#AAA" FontWeight="Thin"/>
                    <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#DDD" TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="HTTP CORE MONITOR" FontSize="24" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,20"/>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Server Control -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Server Configuration" Foreground="#AAA" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" Width="250" Padding="5" Background="#252526" Foreground="White" BorderBrush="#3F3F46"/>
                    <Button Command="{Binding ToggleServerCommand}" 
                            Padding="15,5" Margin="10,0,0,0" Background="#007ACC" Foreground="White" BorderThickness="0">
                        <!-- Custom styling for button based on server state -->
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="Start Server"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                        <Setter Property="Content" Value="Stop Server"/>
                                        <Setter Property="Background" Value="#D83B01"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Client Control -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Test Client" Foreground="#AAA" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding TestUrl, UpdateSourceTrigger=PropertyChanged}" Width="250" Padding="5" Background="#252526" Foreground="White" BorderBrush="#3F3F46"/>
                    <Button Command="{Binding SendRequestCommand}" Content="Send GET" Padding="15,5" Margin="10,0,0,0" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Logs -->
        <GroupBox Grid.Row="2" Header="Execution Logs" Foreground="#AAA" BorderBrush="#333">
            <ListBox ItemsSource="{Binding Logs}" Background="#121212" BorderThickness="0" HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </GroupBox>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="#007ACC" Foreground="White" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
