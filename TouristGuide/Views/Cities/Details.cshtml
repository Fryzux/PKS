@model TouristGuide.Models.City

@{
    ViewData["Title"] = Model.Name;
    var attractions = Model.Attractions ?? new List<TouristGuide.Models.Attraction>();
    int count = attractions.Count;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Города</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="card detail-card mb-4">
    <div class="card-body p-4">
        <div class="row g-4">
            <div class="col-md-7">
                <div class="d-flex align-items-start gap-3 mb-2">
                    @if (!string.IsNullOrEmpty(Model.CoatOfArmsUrl))
                    {
                        <img src="@Model.CoatOfArmsUrl" alt="Герб @Model.Name"
                             style="width:56px; height:56px; object-fit:contain; flex-shrink:0;" />
                    }
                    <div>
                        <h1 class="fw-bold mb-1">@Model.Name</h1>
                        <p class="text-muted mb-0">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i>@Model.Region
                            &nbsp;·&nbsp;
                            <span class="pop-badge">
                                <i class="bi bi-people-fill me-1"></i>@Model.Population.ToString("N0") чел.
                            </span>
                        </p>
                    </div>
                </div>

                <hr />

                @if (!string.IsNullOrEmpty(Model.History))
                {
                    <h5 class="section-title mb-3">История</h5>
                    <p class="text-secondary lh-lg">@Model.History</p>
                }

                <div class="mt-4 d-flex flex-wrap gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>К списку
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>Редактировать
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Удалить
                    </a>
                </div>
            </div>

            <div class="col-md-5 text-center mt-2 mt-md-0">
                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                {
                    <img src="@Model.PhotoUrl" alt="@Model.Name" class="detail-hero-img" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center rounded-3"
                         style="height:240px; background:linear-gradient(135deg,#eef2ff,#e0e7ff);">
                        <i class="bi bi-buildings display-1 text-primary opacity-40"></i>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center gap-3">
        <h2 class="section-title mb-0">Достопримечательности</h2>
        @if (count > 0)
        {
            <span class="badge rounded-pill text-bg-primary fs-6 px-3">@count</span>
        }
    </div>
    <a asp-controller="Attractions" asp-action="Create" asp-route-cityId="@Model.Id" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>Добавить
    </a>
</div>

@if (count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-map display-3 d-block mb-3 opacity-40"></i>
        <p class="fs-5 mb-1 fw-semibold">Достопримечательности пока не добавлены</p>
        <p class="small mb-4">Станьте первым, кто откроет этот город</p>
        <a asp-controller="Attractions" asp-action="Create" asp-route-cityId="@Model.Id"
           class="btn btn-success px-4">
            <i class="bi bi-plus-circle me-1"></i>Добавить первую
        </a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var attraction in attractions)
        {
            <div class="col-md-4">
                <div class="card attraction-card h-100">
                    <img src="@(string.IsNullOrEmpty(attraction.PhotoUrl) ? "/images/no-image.jpg" : attraction.PhotoUrl)"
                         class="card-img-top" alt="@attraction.Name" style="height:185px; object-fit:cover;">
                    <div class="card-body d-flex flex-column p-3">
                        <h5 class="card-title fw-bold mb-1">@attraction.Name</h5>

                        @if (!string.IsNullOrEmpty(attraction.BriefDescription))
                        {
                            <p class="card-text text-muted small flex-grow-1 mb-2">@attraction.BriefDescription</p>
                        }
                        else
                        {
                            <div class="flex-grow-1"></div>
                        }

                        @if (!string.IsNullOrEmpty(attraction.OpeningHours) || !string.IsNullOrEmpty(attraction.Cost))
                        {
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                @if (!string.IsNullOrEmpty(attraction.OpeningHours))
                                {
                                    <span class="city-chip">
                                        <i class="bi bi-clock text-primary"></i>@attraction.OpeningHours
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(attraction.Cost))
                                {
                                    <span class="city-chip">
                                        <i class="bi bi-ticket-perforated text-success"></i>@attraction.Cost
                                    </span>
                                }
                            </div>
                        }

                        <div class="d-flex justify-content-between align-items-center mt-1">
                            <a asp-controller="Attractions" asp-action="Details" asp-route-id="@attraction.Id"
                               class="btn btn-sm btn-primary px-3">Подробнее</a>
                            <div class="d-flex gap-1">
                                <a asp-controller="Attractions" asp-action="Edit" asp-route-id="@attraction.Id"
                                   class="btn btn-sm btn-outline-secondary btn-icon" title="Редактировать">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-controller="Attractions" asp-action="Delete" asp-route-id="@attraction.Id"
                                   class="btn btn-sm btn-outline-danger btn-icon" title="Удалить">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
