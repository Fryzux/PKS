@model TouristGuide.Models.Attraction

@{
    ViewData["Title"] = "Удалить достопримечательность";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card form-card border-0">
            <div class="card-header text-white" style="background: linear-gradient(135deg, #e11d48 0%, #f43f5e 100%); border-radius: 16px 16px 0 0 !important;">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <h4 class="mb-0">Удаление достопримечательности</h4>
                </div>
            </div>
            <div class="card-body p-4 text-center">
                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                {
                    <img src="@Model.PhotoUrl" class="rounded-3 shadow mb-4"
                         style="max-height: 180px; max-width: 100%; object-fit: cover;" alt="@Model.Name" />
                }
                else
                {
                    <div class="mb-4">
                        <i class="bi bi-image display-2 text-danger opacity-50"></i>
                    </div>
                }

                <h4 class="fw-bold mb-1">@Model.Name</h4>
                <p class="text-muted mb-4">
                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                    <a asp-controller="Cities" asp-action="Details" asp-route-id="@Model.CityId"
                       class="text-decoration-none fw-semibold">@Model.City?.Name</a>
                </p>

                <div class="alert alert-warning d-flex align-items-start gap-2 text-start mb-4" role="alert">
                    <i class="bi bi-exclamation-circle-fill mt-1 flex-shrink-0"></i>
                    <div>
                        Это действие <strong>нельзя будет отменить</strong>.
                        Фотография и все данные о достопримечательности будут удалены безвозвратно.
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Cities" asp-action="Details" asp-route-id="@Model.CityId"
                           class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-lg me-1"></i>Отмена
                        </a>
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash-fill me-1"></i>Да, удалить
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
