<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Управление производством</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --primary-light: #818cf8;
            --secondary: #8b5cf6;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #06b6d4;
            --dark-bg: #0f172a;
            --dark-secondary: #1e293b;
            --dark-tertiary: #334155;
            --light-bg: #f8fafc;
            --card-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
            --card-shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -2px rgba(0,0,0,0.04);
        }

        * {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        body {
            background: var(--light-bg);
            color: #1e293b;
        }

        /* Sidebar */
        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
            box-shadow: 2px 0 10px rgba(0,0,0,0.05);
            position: relative;
        }

        .sidebar::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 1px;
            height: 100%;
            background: linear-gradient(180deg, transparent 0%, rgba(99,102,241,0.3) 50%, transparent 100%);
        }

        .sidebar-header {
            padding: 1.5rem 1.5rem;
            color: #fff;
            font-weight: 700;
            font-size: 1.15rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .sidebar-header .logo-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            box-shadow: 0 4px 12px rgba(99,102,241,0.4);
        }

        .sidebar-header .brand-text {
            display: flex;
            flex-direction: column;
        }

        .sidebar-header .brand-text small {
            font-size: 0.7rem;
            font-weight: 400;
            color: #94a3b8;
            margin-top: 2px;
        }

        .sidebar .nav-link {
            color: #94a3b8;
            padding: .75rem 1rem;
            border-radius: 10px;
            margin: 4px 12px;
            font-weight: 500;
            font-size: 0.92rem;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s ease;
            position: relative;
        }

        .sidebar .nav-link:hover {
            background: rgba(99,102,241,0.1);
            color: #fff;
            transform: translateX(2px);
        }

        .sidebar .nav-link.active {
            background: linear-gradient(135deg, rgba(99,102,241,0.2) 0%, rgba(139,92,246,0.15) 100%);
            color: #fff;
            box-shadow: inset 0 0 0 1px rgba(99,102,241,0.3);
        }

        .sidebar .nav-link.active::before {
            content: '';
            position: absolute;
            left: -12px;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 24px;
            background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
            border-radius: 0 4px 4px 0;
        }

        .sidebar .nav-link i {
            font-size: 1.15rem;
            width: 22px;
            text-align: center;
        }

        .sidebar-section {
            padding: 1rem 1.5rem 0.5rem;
            color: #64748b;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Top Navbar */
        .top-navbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 1rem 1.75rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        }

        .top-navbar .page-title {
            font-size: 1.35rem;
            font-weight: 700;
            color: #0f172a;
            margin: 0;
        }

        .top-navbar .page-subtitle {
            font-size: 0.85rem;
            color: #64748b;
            margin: 0;
        }

        .top-navbar .nav-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav-action-btn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: #f1f5f9;
            border: none;
            color: #475569;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            position: relative;
        }

        .nav-action-btn:hover {
            background: #e2e8f0;
            color: var(--primary);
        }

        .nav-action-btn .badge-dot {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--danger);
            border: 2px solid #fff;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(99,102,241,0.3);
        }

        /* Cards */
        .card {
            border: none;
            border-radius: 14px;
            box-shadow: var(--card-shadow);
            transition: all 0.2s ease;
            background: #fff;
        }

        .card:hover {
            box-shadow: var(--card-shadow-hover);
        }

        .card-header {
            background: #fff !important;
            border-bottom: 1px solid #f1f5f9;
            padding: 1.1rem 1.25rem;
            font-weight: 600;
            color: #0f172a;
        }

        .card-body {
            padding: 1.25rem;
        }

        /* Stat Cards */
        .stat-card {
            border-radius: 14px;
            padding: 1.5rem;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
            border: none;
        }

        .stat-card:hover {
            transform: translateY(-3px);
        }

        .stat-card .stat-icon {
            position: absolute;
            top: 1rem;
            right: 1rem;
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }

        .stat-card .stat-value {
            font-size: 2.25rem;
            font-weight: 800;
            line-height: 1.1;
            margin-top: 1rem;
        }

        .stat-card .stat-label {
            font-size: 0.85rem;
            font-weight: 500;
            color: #64748b;
            margin-top: 0.25rem;
        }

        .stat-card .stat-change {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.25rem 0.5rem;
            border-radius: 6px;
            margin-top: 0.75rem;
        }

        .stat-card.primary { background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%); }
        .stat-card.primary .stat-icon { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); color: #fff; }
        .stat-card.primary .stat-value { color: var(--primary-dark); }

        .stat-card.success { background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); }
        .stat-card.success .stat-icon { background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: #fff; }
        .stat-card.success .stat-value { color: #047857; }

        .stat-card.warning { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); }
        .stat-card.warning .stat-icon { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: #fff; }
        .stat-card.warning .stat-value { color: #b45309; }

        .stat-card.info { background: linear-gradient(135deg, #cffafe 0%, #a5f3fc 100%); }
        .stat-card.info .stat-icon { background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); color: #fff; }
        .stat-card.info .stat-value { color: #0e7490; }

        /* Status badges */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.3rem 0.7rem;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .status-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
        }

        .status-Active, .status-badge.active { background: #d1fae5; color: #047857; }
        .status-Stopped, .status-badge.stopped { background: #f1f5f9; color: #475569; }
        .status-Pending, .status-badge.pending { background: #cffafe; color: #0e7490; }
        .status-InProgress, .status-badge.inprogress { background: #dbeafe; color: #1e40af; }
        .status-Completed, .status-badge.completed { background: #d1fae5; color: #047857; }
        .status-Cancelled, .status-badge.cancelled { background: #fee2e2; color: #991b1b; }

        /* Tables */
        .table {
            margin: 0;
        }

        .table thead th {
            background: #f8fafc;
            color: #64748b;
            font-weight: 600;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            padding: 0.85rem 1.25rem;
            border-bottom: 1px solid #e2e8f0;
        }

        .table tbody td {
            padding: 1rem 1.25rem;
            vertical-align: middle;
            border-color: #f1f5f9;
            font-size: 0.92rem;
        }

        .table tbody tr {
            transition: background 0.15s ease;
        }

        .table tbody tr:hover {
            background: #f8fafc;
        }

        /* Buttons */
        .btn {
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-sm {
            padding: 0.35rem 0.7rem;
            font-size: 0.85rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            border: none;
            box-shadow: 0 2px 8px rgba(99,102,241,0.3);
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, var(--primary-dark) 0%, #4338ca 100%);
            box-shadow: 0 4px 12px rgba(99,102,241,0.4);
            transform: translateY(-1px);
        }

        .btn-success {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border: none;
            box-shadow: 0 2px 8px rgba(16,185,129,0.3);
        }

        .btn-danger {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            border: none;
            box-shadow: 0 2px 8px rgba(239,68,68,0.3);
        }

        .btn-warning {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            border: none;
            color: #fff;
            box-shadow: 0 2px 8px rgba(245,158,11,0.3);
        }

        .btn-warning:hover {
            color: #fff;
        }

        .btn-outline-secondary {
            border-color: #e2e8f0;
            color: #475569;
            background: #fff;
        }

        .btn-outline-secondary:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
            color: #0f172a;
        }

        .btn-icon {
            width: 34px;
            height: 34px;
            padding: 0;
            justify-content: center;
        }

        /* Progress bars */
        .progress {
            height: 8px;
            border-radius: 100px;
            background: #f1f5f9;
            overflow: hidden;
        }

        .progress-bar {
            background: linear-gradient(90deg, var(--primary) 0%, var(--secondary) 100%);
            transition: width 0.6s ease;
            border-radius: 100px;
        }

        .progress-bar.bg-success {
            background: linear-gradient(90deg, #10b981 0%, #059669 100%);
        }

        /* Badges */
        .badge {
            font-weight: 600;
            padding: 0.35em 0.7em;
            border-radius: 6px;
            font-size: 0.72rem;
        }

        /* Production Line Cards */
        .line-card {
            border-radius: 14px;
            border: none;
            overflow: hidden;
            box-shadow: var(--card-shadow);
            transition: all 0.3s ease;
            background: #fff;
        }

        .line-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--card-shadow-hover);
        }

        .line-card.active {
            border-top: 4px solid #10b981;
        }

        .line-card.stopped {
            border-top: 4px solid #94a3b8;
        }

        .line-card .line-header {
            padding: 1.25rem;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 1px solid #f1f5f9;
        }

        .line-card .line-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            margin-bottom: 0.5rem;
        }

        .line-card.active .line-icon {
            background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
            color: #047857;
        }

        .line-card.stopped .line-icon {
            background: #f1f5f9;
            color: #64748b;
        }

        .line-card .line-name {
            font-weight: 700;
            font-size: 1rem;
            color: #0f172a;
            margin: 0;
        }

        .line-card .line-status-text {
            font-size: 0.78rem;
            color: #64748b;
            margin-top: 2px;
        }

        /* Forms */
        .form-control, .form-select {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 0.55rem 0.85rem;
            font-size: 0.92rem;
            transition: all 0.2s;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
        }

        .form-label {
            font-weight: 500;
            font-size: 0.85rem;
            color: #475569;
            margin-bottom: 0.4rem;
        }

        /* Alerts */
        .alert {
            border: none;
            border-radius: 10px;
            padding: 0.85rem 1.1rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-success {
            background: #ecfdf5;
            color: #047857;
        }

        .alert-danger {
            background: #fef2f2;
            color: #991b1b;
        }

        .alert-info {
            background: #eff6ff;
            color: #1e40af;
        }

        /* Modals */
        .modal-content {
            border: none;
            border-radius: 16px;
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
        }

        .modal-header {
            border-bottom: 1px solid #f1f5f9;
            padding: 1.25rem 1.5rem;
        }

        .modal-title {
            font-weight: 700;
            color: #0f172a;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            border-top: 1px solid #f1f5f9;
            padding: 1rem 1.5rem;
        }

        /* Filter Pills */
        .filter-pills {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .filter-pill {
            padding: 0.45rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
            background: #fff;
            border: 1px solid #e2e8f0;
            color: #475569;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .filter-pill:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: #cbd5e1;
        }

        .filter-pill.active {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            border-color: var(--primary);
            box-shadow: 0 2px 8px rgba(99,102,241,0.3);
        }

        /* Main content */
        main {
            padding: 1.75rem;
            min-height: calc(100vh - 73px);
        }

        /* Quantity indicator (for low stock) */
        .quantity-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.25rem 0.65rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .quantity-indicator.low {
            background: #fef2f2;
            color: #991b1b;
        }

        .quantity-indicator.normal {
            background: #f0fdf4;
            color: #166534;
        }

        /* Empty state */
        .empty-state {
            padding: 3rem 1rem;
            text-align: center;
            color: #94a3b8;
        }

        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        /* Animations */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.4s ease;
        }

        /* Range slider */
        .form-range::-webkit-slider-thumb {
            background: var(--primary);
        }

        .form-range::-moz-range-thumb {
            background: var(--primary);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                z-index: 1000;
                transform: translateX(-100%);
                transition: transform 0.3s;
            }
            .sidebar.show {
                transform: translateX(0);
            }
            main {
                padding: 1rem;
            }
        }
    </style>
</head>
<body class="bg-light">
<div class="d-flex">
    <div class="sidebar d-flex flex-column" style="width:260px; min-width:260px;">
        <div class="sidebar-header">
            <div class="logo-icon">
                <i class="bi bi-gear-fill"></i>
            </div>
            <div class="brand-text">
                <span>ПК Производство</span>
                <small>Система управления</small>
            </div>
        </div>

        <div class="sidebar-section">Главное</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Дашборд</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-section">Производство</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WorkOrders" ? "active" : "")"
                   asp-controller="WorkOrders" asp-action="Index">
                    <i class="bi bi-clipboard-check-fill"></i>
                    <span>Заказы</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProductionLines" ? "active" : "")"
                   asp-controller="ProductionLines" asp-action="Index">
                    <i class="bi bi-cpu-fill"></i>
                    <span>Линии</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-section">Каталог</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")"
                   asp-controller="Products" asp-action="Index">
                    <i class="bi bi-box-seam-fill"></i>
                    <span>Продукты</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Materials" ? "active" : "")"
                   asp-controller="Materials" asp-action="Index">
                    <i class="bi bi-bricks"></i>
                    <span>Материалы</span>
                </a>
            </li>
        </ul>
    </div>

    <div class="flex-grow-1 d-flex flex-column">
        <nav class="top-navbar">
            <div>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <p class="page-subtitle">@DateTime.Now.ToString("dddd, d MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))</p>
            </div>
            <div class="nav-actions">
                <button class="nav-action-btn" title="Поиск">
                    <i class="bi bi-search"></i>
                </button>
                <button class="nav-action-btn" title="Уведомления">
                    <i class="bi bi-bell-fill"></i>
                    @{
                        var lowStockAlert = ViewBag.LowStockCount is int lsc && lsc > 0;
                    }
                    @if (lowStockAlert)
                    {
                        <span class="badge-dot"></span>
                    }
                </button>
                <div class="user-avatar" title="Пользователь">
                    АД
                </div>
            </div>
        </nav>
        <main class="fade-in">
            @if (TempData["Success"] is string successMsg)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@successMsg</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] is string errorMsg)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span>@errorMsg</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
