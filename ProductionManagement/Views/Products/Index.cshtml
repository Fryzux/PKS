@model IEnumerable<ProductionManagement.Models.Product>
@{
    ViewData["Title"] = "Продукты";
    var categories = ViewBag.Categories as IEnumerable<string>;
}

<!-- Filters Card -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">
                    <i class="bi bi-search"></i> Поиск по названию
                </label>
                <input name="search" class="form-control" placeholder="Введите название продукта..." value="@ViewBag.Search" />
            </div>
            <div class="col-md-4">
                <label class="form-label">
                    <i class="bi bi-tag-fill"></i> Категория
                </label>
                <select name="category" class="form-select">
                    <option value="">Все категории</option>
                    @foreach (var c in categories ?? Enumerable.Empty<string>())
                    {
                        <option value="@c" selected="@(ViewBag.SelectedCategory == c ? "selected" : null)">@c</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-funnel-fill"></i> Применить
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Products Card -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-box-seam-fill text-primary"></i>
            <span>Каталог продуктов</span>
            <span class="badge bg-light text-dark">@Model.Count()</span>
        </div>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="bi bi-plus-lg"></i> Создать продукт
        </button>
    </div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Продукт</th>
                    <th>Категория</th>
                    <th>Время производства</th>
                    <th>Мин. запас</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded p-2" style="background: #eef2ff; color: var(--primary);">
                                    <i class="bi bi-box-fill"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold">@p.Name</div>
                                    <small class="text-muted">@p.Description</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.Category))
                            {
                                <span class="badge bg-light text-dark border">
                                    <i class="bi bi-tag-fill"></i> @p.Category
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <span class="d-flex align-items-center gap-1">
                                <i class="bi bi-clock text-muted"></i>
                                <span class="fw-semibold">@p.ProductionTimePerUnit</span>
                                <span class="text-muted small">мин/шт</span>
                            </span>
                        </td>
                        <td>
                            <span class="text-muted">@p.MinimalStock шт</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-arrow-right-circle"></i> Открыть
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <div class="empty-state-icon"><i class="bi bi-search"></i></div>
                                <div>Продукты не найдены</div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle-fill text-primary"></i> Новый продукт</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="Create">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Название <span class="text-danger">*</span></label>
                        <input name="Name" class="form-control" required placeholder="Введите название продукта" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Описание</label>
                        <textarea name="Description" class="form-control" rows="2" placeholder="Краткое описание продукта"></textarea>
                    </div>
                    <div class="row">
                        <div class="col">
                            <label class="form-label">Категория</label>
                            <input name="Category" class="form-control" placeholder="Например: Электроника" />
                        </div>
                        <div class="col">
                            <label class="form-label">Время произв. (мин) <span class="text-danger">*</span></label>
                            <input name="ProductionTimePerUnit" type="number" min="1" class="form-control" value="60" required />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Минимальный запас (шт)</label>
                        <input name="MinimalStock" type="number" min="0" class="form-control" value="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-lg"></i> Создать</button>
                </div>
            </form>
        </div>
    </div>
</div>
