@model ProductionManagement.Models.Product
@{
    ViewData["Title"] = Model.Name;
    var allMaterials = ViewBag.AllMaterials as IEnumerable<ProductionManagement.Models.Material> ?? Enumerable.Empty<ProductionManagement.Models.Material>();
    var usedIds = Model.ProductMaterials.Select(pm => pm.MaterialId).ToHashSet();
    var available = allMaterials.Where(m => !usedIds.Contains(m.Id)).ToList();
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад к каталогу
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-info-circle-fill text-primary"></i>
                <span>Информация о продукте</span>
            </div>
            <form method="post" asp-action="Edit">
                <div class="card-body">
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="Specifications" value="@Model.Specifications" />

                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                             style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); color: #fff; font-size: 2rem;">
                            <i class="bi bi-box-fill"></i>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input name="Name" class="form-control" value="@Model.Name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Описание</label>
                        <textarea name="Description" class="form-control" rows="2">@Model.Description</textarea>
                    </div>
                    <div class="row">
                        <div class="col">
                            <label class="form-label">Категория</label>
                            <input name="Category" class="form-control" value="@Model.Category" />
                        </div>
                        <div class="col">
                            <label class="form-label">Время (мин/шт)</label>
                            <input name="ProductionTimePerUnit" type="number" min="1" class="form-control" value="@Model.ProductionTimePerUnit" required />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Минимальный запас</label>
                        <input name="MinimalStock" type="number" min="0" class="form-control" value="@Model.MinimalStock" />
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Сохранить изменения
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-bricks text-primary"></i>
                    <span>Необходимые материалы</span>
                    <span class="badge bg-light text-dark">@Model.ProductMaterials.Count</span>
                </div>
                @if (available.Any())
                {
                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addMaterialModal">
                        <i class="bi bi-plus-lg"></i> Добавить
                    </button>
                }
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Материал</th>
                            <th>На 1 единицу</th>
                            <th>Ед.изм.</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pm in Model.ProductMaterials)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded p-2" style="background: #f0fdf4; color: #166534;">
                                            <i class="bi bi-box-fill"></i>
                                        </div>
                                        <span class="fw-semibold">@pm.Material.Name</span>
                                    </div>
                                </td>
                                <td><span class="fw-semibold">@pm.QuantityNeeded</span></td>
                                <td class="text-muted">@pm.Material.UnitOfMeasure</td>
                                <td class="text-end">
                                    <form method="post" asp-action="RemoveMaterial" style="display:inline"
                                          onsubmit="return confirm('Удалить материал из продукта?')">
                                        <input type="hidden" name="productId" value="@Model.Id" />
                                        <input type="hidden" name="materialId" value="@pm.MaterialId" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary btn-icon" title="Удалить">
                                            <i class="bi bi-trash text-danger"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.ProductMaterials.Any())
                        {
                            <tr>
                                <td colspan="4">
                                    <div class="empty-state">
                                        <div class="empty-state-icon"><i class="bi bi-bricks"></i></div>
                                        <div>Материалы не привязаны</div>
                                        @if (available.Any())
                                        {
                                            <button class="btn btn-primary btn-sm mt-3" data-bs-toggle="modal" data-bs-target="#addMaterialModal">
                                                <i class="bi bi-plus-lg"></i> Добавить материал
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Production Time Info -->
        <div class="card mt-3">
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <i class="bi bi-clock-fill fs-3 text-primary"></i>
                        <div class="fs-4 fw-bold">@Model.ProductionTimePerUnit</div>
                        <small class="text-muted">мин/шт</small>
                    </div>
                    <div class="col-4 border-start border-end">
                        <i class="bi bi-tag-fill fs-3 text-info"></i>
                        <div class="fs-6 fw-bold">@(Model.Category ?? "—")</div>
                        <small class="text-muted">Категория</small>
                    </div>
                    <div class="col-4">
                        <i class="bi bi-archive-fill fs-3 text-warning"></i>
                        <div class="fs-4 fw-bold">@Model.MinimalStock</div>
                        <small class="text-muted">Мин. запас</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (available.Any())
{
    <div class="modal fade" id="addMaterialModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-circle-fill text-primary"></i> Добавить материал</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-action="AddMaterial">
                    <div class="modal-body">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Материал</label>
                            <select name="materialId" class="form-select" required>
                                @foreach (var m in available)
                                {
                                    <option value="@m.Id">@m.Name (@m.UnitOfMeasure)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Кол-во на 1 ед. продукта</label>
                            <input name="quantityNeeded" type="number" step="0.001" min="0.001" class="form-control" value="1" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-lg"></i> Добавить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
