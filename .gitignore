# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# SQLite databases (local data, not for source control)
*.db
*.db-shm
*.db-wal

# Log files
logs.txt
logs_export.txt
*.log

# OS files
.DS_Store
Thumbs.db
