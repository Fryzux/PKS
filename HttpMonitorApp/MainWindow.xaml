<Window x:Class="WpfHttpApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHttpApp"
        xmlns:vm="clr-namespace:WpfHttpApp.ViewModels"
        xmlns:models="clr-namespace:WpfHttpApp.Models"
        mc:Ignorable="d"
        Title="HTTP Monitor — WPF" Height="720" Width="1100"
        Background="#0D1117"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:CountToHeightConverter x:Key="CountToHeight"/>

        <!-- ═══ COLORS ═══════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgPrimary"   Color="#0D1117"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#161B22"/>
        <SolidColorBrush x:Key="BgCard"      Color="#1C2128"/>
        <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#F85149"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#D29922"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#8B949E"/>

        <!-- ═══ TEXTBOX ════════════════════════════════════════════════════ -->
        <Style TargetType="TextBox" x:Key="DarkTextBox">
            <Setter Property="Background"   Value="#0D1117"/>
            <Setter Property="Foreground"   Value="#E6EDF3"/>
            <Setter Property="BorderBrush"  Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,6"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="CaretBrush"   Value="#58A6FF"/>
            <Setter Property="SelectionBrush" Value="#1F6FEB"/>
        </Style>

        <!-- ═══ BUTTON ════════════════════════════════════════════════════ -->
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background"   Value="#1F6FEB"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#388BFD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1158C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#B91C1C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ COMBOBOX ═══════════════════════════════════════════════════ -->
        <Style TargetType="ComboBox" x:Key="DarkCombo">
            <Setter Property="Background"   Value="#161B22"/>
            <Setter Property="Foreground"   Value="#E6EDF3"/>
            <Setter Property="BorderBrush"  Value="#30363D"/>
            <Setter Property="Padding"      Value="8,5"/>
            <Setter Property="FontSize"     Value="13"/>
        </Style>

        <!-- ═══ TAB ════════════════════════════════════════════════════════ -->
        <Style TargetType="TabControl" x:Key="DarkTab">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="0"/>
        </Style>

        <Style TargetType="TabItem" x:Key="DarkTabItem">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Foreground"   Value="#8B949E"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="16,10"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ LOG ENTRY TEMPLATE ════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type models:LogEntry}">
            <Border Padding="8,4" BorderThickness="0,0,0,1" BorderBrush="#21262D">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Timestamp -->
                    <TextBlock Grid.Column="0" Foreground="#6E7681" FontSize="11" VerticalAlignment="Center"
                               Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"/>

                    <!-- Level badge -->
                    <Border Grid.Column="1" CornerRadius="3" Padding="5,2" Margin="3,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#21262D"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Level}" Value="Info">
                                        <Setter Property="Background" Value="#1B3A29"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                        <Setter Property="Background" Value="#3A2F1B"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                        <Setter Property="Background" Value="#3A1B1B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#8B949E"/>
                                    <Setter Property="Text" Value="{Binding Level}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="Info">
                                            <Setter Property="Foreground" Value="#3FB950"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                                            <Setter Property="Foreground" Value="#D29922"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                            <Setter Property="Foreground" Value="#F85149"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Method badge -->
                    <Border Grid.Column="2" CornerRadius="3" Padding="5,2" Margin="2,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Method}" Value="GET">
                                        <Setter Property="Background" Value="#1B2A3A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Method}" Value="POST">
                                        <Setter Property="Background" Value="#2A1B3A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10" FontWeight="Bold" Text="{Binding Method}" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Method}" Value="GET">
                                            <Setter Property="Foreground" Value="#58A6FF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Method}" Value="POST">
                                            <Setter Property="Foreground" Value="#BC8CFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Status Code -->
                    <TextBlock Grid.Column="3" FontSize="11" VerticalAlignment="Center" Margin="3,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Transparent"/>
                                <Setter Property="Text" Value="{Binding StatusCode}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusCode}" Value="0">
                                        <Setter Property="Foreground" Value="Transparent"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusCode}" Value="200">
                                        <Setter Property="Foreground" Value="#3FB950"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusCode}" Value="404">
                                        <Setter Property="Foreground" Value="#D29922"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusCode}" Value="400">
                                        <Setter Property="Foreground" Value="#F85149"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusCode}" Value="500">
                                        <Setter Property="Foreground" Value="#F85149"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Source -->
                    <TextBlock Grid.Column="4" Text="{Binding Source}" Foreground="#6E7681" FontSize="11" VerticalAlignment="Center" Margin="3,0"/>

                    <!-- Message -->
                    <TextBlock Grid.Column="5" Text="{Binding Message}" Foreground="#C9D1D9" FontSize="12"
                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ HEADER ═══════════════════════════════ -->
        <Border Grid.Row="0" Background="#161B22" BorderThickness="0,0,0,1" BorderBrush="#30363D">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Indicator dot -->
                    <Ellipse Width="10" Height="10" Margin="0,0,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#F85149"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                        <Setter Property="Fill" Value="#3FB950"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="HTTP Monitor" FontSize="18" FontWeight="Bold" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                    <TextBlock Text=" — WPF + HttpListener + HttpClient" FontSize="13" Foreground="#8B949E" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Mini stats -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="GET " Foreground="#58A6FF" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="{Binding GetCount}" Foreground="#E6EDF3" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="POST " Foreground="#BC8CFF" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="{Binding PostCount}" Foreground="#E6EDF3" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏱ " Foreground="#8B949E" FontSize="13"/>
                        <TextBlock Text="{Binding UptimeText}" Foreground="#E6EDF3" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════ TABS ═══════════════════════════════════ -->
        <TabControl Grid.Row="1" Style="{StaticResource DarkTab}" Background="#0D1117">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource DarkTabItem}"/>
            </TabControl.Resources>

            <!-- ──────────────────── TAB 1: SERVER ──────────────────────── -->
            <TabItem Header="🖥  Server">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: controls + stats -->
                    <StackPanel Grid.Column="0">

                        <!-- Server control card -->
                        <Border Background="#161B22" CornerRadius="8" Padding="16" BorderBrush="#30363D" BorderThickness="1" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="SERVER CONFIGURATION" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                <TextBlock Text="Port" Foreground="#8B949E" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox x:Name="PortBox"
                                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,12"/>

                                <Button Command="{Binding ToggleServerCommand}"
                                        HorizontalAlignment="Stretch">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                            <Setter Property="Content" Value="▶  Start Server"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                                    <Setter Property="Content" Value="⏹  Stop Server"/>
                                                    <Setter Property="Background" Value="#B91C1C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Endpoint info -->
                                <Border Margin="0,12,0,0" Background="#0D1117" CornerRadius="4" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Endpoints" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBlock Foreground="#58A6FF" FontSize="11" FontFamily="Consolas">
                                            <Run Text="GET  "/>
                                            <Run Text="/status" Foreground="#C9D1D9"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#BC8CFF" FontSize="11" FontFamily="Consolas" Margin="0,3,0,0">
                                            <Run Text="POST "/>
                                            <Run Text="/messages" Foreground="#C9D1D9"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Stats card -->
                        <Border Background="#161B22" CornerRadius="8" Padding="16" BorderBrush="#30363D" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="SERVER STATISTICS" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <!-- GET count -->
                                    <Border Grid.Column="0" Grid.Row="0" Background="#0D1117" CornerRadius="6" Padding="12" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="GET Requests" Foreground="#6E7681" FontSize="11"/>
                                            <TextBlock Text="{Binding GetCount}" Foreground="#58A6FF" FontSize="28" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- POST count -->
                                    <Border Grid.Column="1" Grid.Row="0" Background="#0D1117" CornerRadius="6" Padding="12" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="POST Requests" Foreground="#6E7681" FontSize="11"/>
                                            <TextBlock Text="{Binding PostCount}" Foreground="#BC8CFF" FontSize="28" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Avg time -->
                                    <Border Grid.Column="0" Grid.Row="2" Background="#0D1117" CornerRadius="6" Padding="12" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="Avg Response (ms)" Foreground="#6E7681" FontSize="11"/>
                                            <TextBlock Text="{Binding AvgProcessingMs}" Foreground="#3FB950" FontSize="28" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Stored messages -->
                                    <Border Grid.Column="1" Grid.Row="2" Background="#0D1117" CornerRadius="6" Padding="12" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Stored Messages" Foreground="#6E7681" FontSize="11"/>
                                            <TextBlock Text="{Binding StoredMessagesCount}" Foreground="#D29922" FontSize="28" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right: stored messages list -->
                    <Border Grid.Column="2" Background="#161B22" CornerRadius="8" Padding="16" BorderBrush="#30363D" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="STORED POST MESSAGES" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <ListBox Grid.Row="1" ItemsSource="{Binding StoredMessages}"
                                     Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding"    Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0D1117" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock Text="ID: " Foreground="#6E7681" FontSize="11" FontFamily="Consolas"/>
                                                    <TextBlock Text="{Binding Id}" Foreground="#58A6FF" FontSize="11" FontFamily="Consolas"/>
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" Text="{Binding Message}" Foreground="#E6EDF3" FontSize="13" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ──────────────────── TAB 2: CLIENT ──────────────────────── -->
            <TabItem Header="📡  Client">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Request panel -->
                    <Border Grid.Column="0" Background="#161B22" CornerRadius="8" Padding="16" BorderBrush="#30363D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="REQUEST BUILDER" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <!-- Method + URL -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding Methods}"
                                          SelectedValue="{Binding SelectedMethod}"
                                          Style="{StaticResource DarkCombo}"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding ClientUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}"
                                         ToolTip="Request URL"/>
                            </Grid>

                            <!-- Body -->
                            <TextBlock Text="Request Body (JSON)" Foreground="#8B949E" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding RequestBody, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="160" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     Margin="0,0,0,16"/>

                            <Button Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding SendRequestCommand}"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding IsSending, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Send " Foreground="White"/>
                                        <TextBlock Text="{Binding SelectedMethod}" Foreground="White" FontWeight="Bold"/>
                                        <TextBlock Text=" Request" Foreground="White"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Quick presets -->
                            <TextBlock Text="Quick Presets" Foreground="#6E7681" FontSize="11" Margin="0,16,0,8"/>
                            <WrapPanel>
                                <Button Content="jsonplaceholder GET" Style="{StaticResource SecondaryBtn}" FontSize="11" Padding="8,5" Margin="0,0,6,6"
                                        Tag="https://jsonplaceholder.typicode.com/posts"
                                        Click="PresetGet_Click"/>
                                <Button Content="Local /status" Style="{StaticResource SecondaryBtn}" FontSize="11" Padding="8,5" Margin="0,0,6,6"
                                        Tag="local_status"
                                        Click="PresetLocalStatus_Click"/>
                                <Button Content="Local POST" Style="{StaticResource SecondaryBtn}" FontSize="11" Padding="8,5"
                                        Tag="local_post"
                                        Click="PresetLocalPost_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Response panel -->
                    <Border Grid.Column="2" Background="#161B22" CornerRadius="8" Padding="16" BorderBrush="#30363D" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                                <TextBlock Text="RESPONSE" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border Margin="12,0,0,0" CornerRadius="10" Padding="8,2" Background="#1B3A29"
                                        Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Loading…" Foreground="#3FB950" FontSize="11"/>
                                </Border>
                            </StackPanel>

                            <TextBox Grid.Row="1"
                                     Text="{Binding ResponseText}"
                                     Style="{StaticResource DarkTextBox}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Background="#0D1117"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ──────────────────── TAB 3: MONITOR ─────────────────────── -->
            <TabItem Header="📊  Monitor">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Chart -->
                    <Border Grid.Row="0" Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Request Rate  (per minute)" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <!-- Bar chart rendered with ItemsControl + Canvas-like layout -->
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Buckets}" Margin="0,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Bar -->
                                            <Grid Grid.Row="0" VerticalAlignment="Bottom">
                                                <Rectangle VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="18" Fill="#1F6FEB"
                                                           RadiusX="3" RadiusY="3">
                                                    <Rectangle.Height>
                                                        <MultiBinding>
                                                            <MultiBinding.Converter>
                                                                <StaticResource ResourceKey="CountToHeight" />
                                                            </MultiBinding.Converter>
                                                            <Binding Path="Count"/>
                                                            <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" Path="DataContext.Buckets"/>
                                                        </MultiBinding>
                                                    </Rectangle.Height>
                                                </Rectangle>
                                                <TextBlock Text="{Binding Count}" Foreground="#58A6FF" FontSize="10"
                                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </Grid>

                                            <!-- Label -->
                                            <TextBlock Grid.Row="1" Text="{Binding Label}" Foreground="#6E7681"
                                                       FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Log filter -->
                    <Border Grid.Row="2" Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Filter:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <TextBlock Text="Method:" Foreground="#6E7681" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox ItemsSource="{Binding FilterMethods}"
                                      SelectedValue="{Binding FilterMethod}"
                                      Style="{StaticResource DarkCombo}"
                                      Width="80" Margin="0,0,12,0"/>

                            <TextBlock Text="Status:" Foreground="#6E7681" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Text="{Binding FilterStatus, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"
                                     Width="70" Padding="6,4"
                                     ToolTip="Filter by status code (e.g. 200, 404)" Margin="0,0,12,0"/>

                            <Button Content="Clear Logs" Style="{StaticResource SecondaryBtn}"
                                    Command="{Binding ClearLogsCommand}"
                                    Padding="12,6" Margin="0,0,12,0"/>

                            <Button Content="💾 Save Logs" Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding SaveLogsCommand}"
                                    Padding="12,6"/>
                        </StackPanel>
                    </Border>

                    <!-- Log list -->
                    <Border Grid.Row="4" Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1" Padding="0">
                        <ListBox ItemsSource="{Binding FilteredLogs}"
                                 Background="#0D1117" BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding"    Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#21262D"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══════════════════════ STATUS BAR ═══════════════════════════ -->
        <Border Grid.Row="2" Background="#161B22" BorderThickness="0,1,0,0" BorderBrush="#30363D">
            <TextBlock Text="{Binding StatusText}" Foreground="#8B949E" VerticalAlignment="Center"
                       Margin="20,0" FontSize="12"/>
        </Border>
    </Grid>
</Window>
